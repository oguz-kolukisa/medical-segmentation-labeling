# Copy to .env and edit if needed. start.sh will create .env on first run.

# cuda | cpu | auto (auto detects nvidia-smi and falls back to cpu)
DEVICE=auto

# Upstream CVAT release pinned — we bump deliberately, never via :latest.
CVAT_VERSION=v2.20.0
CVAT_REPO=https://github.com/cvat-ai/cvat.git

# CVAT UI port on the host. Change if 8080 collides.
CVAT_HOST_PORT=8080

# Hostname/IP that browsers will use to reach CVAT.
# 'auto' = detect this server's primary outbound IP at first start.
# Override with a DNS name (e.g. cvat.example.com) or a public IP for
# cloud/NAT deployments where auto-detection can't see the reachable address.
CVAT_HOST=auto

# MedSAM2 checkpoint variant: tiny | small | base-plus | large.
# tiny is the safe default for CPU machines.
MEDSAM2_VARIANT=tiny

# Auto-created CVAT superuser on first run. Change these before first start
# if you want different credentials. CVAT requires a login — we can't disable
# auth — but with these set the expert just types them once and the browser
# remembers.
CVAT_SUPERUSER_USERNAME=kuzey
CVAT_SUPERUSER_EMAIL=kuzey@kuzey.local
CVAT_SUPERUSER_PASSWORD=kuzey
